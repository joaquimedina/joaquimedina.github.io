---
import ArrowLeft from '../assets/icons/arrow-left.svg';
import ArrowRight from '../assets/icons/arrow-right.svg';
import IconButton from './IconButton.astro';

const { page, class: className } = Astro.props;
---

<nav aria-label="Paginación" class:list={['relative px-12 py-2 text-center', className]}>
    {
        page.url.prev && (
            <IconButton
                class="absolute top-1/2 left-0 -translate-y-1/2"
                href={page.url.prev}
                aria-label={`Ir a la página ${page.currentPage - 1} de ${page.lastPage}`}
            >
                <ArrowLeft class="h-5 w-5 fill-current" />
            </IconButton>
        )
    }
    <span class="text-sm text-[var(--accent-warm)]" aria-current="page">Página {page.currentPage} de {page.lastPage}</span>
    {
        page.url.next && (
            <IconButton
                class="absolute top-1/2 right-0 -translate-y-1/2"
                href={page.url.next}
                aria-label={`Ir a la página ${page.currentPage + 1} de ${page.lastPage}`}
            >
                <ArrowRight class="h-5 w-5 fill-current" />
            </IconButton>
        )
    }
</nav>
