---
import NavLink from './NavLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import siteConfig from '../data/site-config';

const navLinks = siteConfig.headerNavLinks ?? [];
---

<nav class="relative min-h-10 pt-4 pb-12 sm:min-h-14 sm:pb-24 md:pt-8" aria-label="Navegación principal">
    {
        navLinks.length > 0 && (
            <div class="relative mx-auto w-full max-w-3xl">
                <button
                    class="menu-toggle relative z-30 -ml-1 flex h-8 w-8 cursor-pointer items-center justify-center md:hidden"
                    aria-label="Abrir menú"
                    aria-expanded="false"
                    aria-controls="menu-items"
                >
                    <span class="menu-toggle-icon relative h-px w-6 bg-current" />
                </button>
                <ul
                    id="menu-items"
                    class="menu max-md:bg-main max-md:border-main flex gap-6 max-md:absolute max-md:-top-2.5 max-md:-left-2.5 max-md:z-20 max-md:flex-col max-md:gap-1 max-md:border max-md:border-dashed max-md:px-3 max-md:pt-16 max-md:pb-10"
                >
                    {navLinks.map((link) => (
                        <li class="py-1">
                            <NavLink
                                class="nav-link text-main font-serif text-xl hover:underline hover:decoration-1 hover:underline-offset-2 md:text-base"
                                href={link.href}
                            >
                                {link.text}
                            </NavLink>
                        </li>
                    ))}
                </ul>
            </div>
        )
    }
    <div class="absolute top-4 right-0 z-10 md:top-8">
        <ThemeToggle />
    </div>
</nav>

<style>
    @reference "tailwindcss";

    @media (max-width: 767px) {
        .menu {
            @apply invisible opacity-0;
            width: min(20rem, calc(100vw - 2rem));
            box-shadow: 0 1.25rem 2.5rem color-mix(in srgb, var(--text-main) 12%, transparent);
            transform: translateY(-0.25rem);
            transition:
                opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s linear 0.2s;
        }
        .menu:before {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            left: 0.75rem;
            height: 1px;
            content: '';
            background: linear-gradient(90deg, var(--accent-warm), var(--accent-cool));
            opacity: 0.8;
        }
        .menu.is-visible {
            @apply visible opacity-100;
            transform: translateY(0);
            transition:
                opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0s;
        }
        .menu-toggle-icon {
            transition: width 0.1s cubic-bezier(0.4, 0, 0.2, 1) 0.3s;
        }
        .menu-toggle.is-active .menu-toggle-icon {
            @apply w-0;
            transition: width 0.1s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .menu-toggle-icon:before,
        .menu-toggle-icon:after {
            @apply absolute top-0 left-1/2 h-px w-6 origin-center -translate-x-1/2 bg-current;
            content: '';
            transition:
                rotate 0.2s cubic-bezier(0.4, 0, 0.2, 1),
                margin 0.2s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;
        }
        .menu-toggle-icon:before {
            @apply -mt-1.5;
        }
        .menu-toggle-icon:after {
            @apply mt-1.5;
        }
        .menu-toggle.is-active .menu-toggle-icon:before,
        .menu-toggle.is-active .menu-toggle-icon:after {
            @apply mt-0;
            transition:
                margin 0.2s cubic-bezier(0.4, 0, 0.2, 1) 0.1s,
                rotate 0.2s cubic-bezier(0.4, 0, 0.2, 1) 0.3s;
        }
        .menu-toggle.is-active .menu-toggle-icon:before {
            @apply rotate-45;
        }
        .menu-toggle.is-active .menu-toggle-icon:after {
            @apply -rotate-45;
        }
    }

    .menu-toggle:focus-visible,
    .nav-link:focus-visible {
        outline: 2px solid var(--accent-cool);
        outline-offset: 0.25rem;
    }

    .nav-link {
        text-decoration-color: currentColor;
        transition:
            color 0.18s ease,
            text-decoration-color 0.18s ease;
    }

    .nav-link:hover,
    .nav-link:focus-visible {
        text-decoration-color: var(--accent-warm);
    }

    .nav-link.is-active {
        text-decoration-color: var(--accent-cool);
    }
</style>

<script>
    function menuToggle() {
        const menu = document.querySelector('.menu');
        const menuToggleBtn = document.querySelector('.menu-toggle');
        if (!(menu instanceof HTMLElement) || !(menuToggleBtn instanceof HTMLButtonElement)) return;

        const menuElement = menu;
        const menuToggleButton = menuToggleBtn;
        const menuLinks = Array.from(menuElement.querySelectorAll('a'));

        function isOpen() {
            return menuToggleButton.getAttribute('aria-expanded') === 'true';
        }

        function openMenu() {
            menuToggleButton.classList.add('is-active');
            menuToggleButton.setAttribute('aria-expanded', 'true');
            menuToggleButton.setAttribute('aria-label', 'Cerrar menú');
            menuElement.classList.add('is-visible');
            menuLinks[0]?.focus();
        }

        function closeMenu({ restoreFocus = false } = {}) {
            menuToggleButton.classList.remove('is-active');
            menuToggleButton.setAttribute('aria-expanded', 'false');
            menuToggleButton.setAttribute('aria-label', 'Abrir menú');
            menuElement.classList.remove('is-visible');
            if (restoreFocus) menuToggleButton.focus();
        }

        menuToggleButton.addEventListener('click', () => {
            if (isOpen()) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        menuElement.addEventListener('click', (event) => {
            const target = event.target;
            if (target instanceof Element && target.closest('a')) closeMenu();
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && isOpen()) {
                closeMenu({ restoreFocus: true });
            }

            if (event.key !== 'Tab' || !isOpen() || menuLinks.length === 0) return;

            const firstLink = menuLinks[0];
            const lastLink = menuLinks[menuLinks.length - 1];
            if (event.shiftKey && document.activeElement === firstLink) {
                event.preventDefault();
                lastLink.focus();
            } else if (!event.shiftKey && document.activeElement === lastLink) {
                event.preventDefault();
                firstLink.focus();
            }
        });

        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Node) || !isOpen()) return;
            if (!menuElement.contains(target) && !menuToggleButton.contains(target)) closeMenu();
        });

        window.addEventListener('resize', () => {
            if (window.matchMedia('(min-width: 768px)').matches && isOpen()) closeMenu();
        });
    }
    menuToggle();
</script>
