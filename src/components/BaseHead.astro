---
import atkinsonBoldItalicWoff2 from '@fontsource/atkinson-hyperlegible/files/atkinson-hyperlegible-latin-ext-700-italic.woff2?url';
import atkinsonBoldWoff2 from '@fontsource/atkinson-hyperlegible/files/atkinson-hyperlegible-latin-ext-700-normal.woff2?url';
import atkinsonItalicWoff2 from '@fontsource/atkinson-hyperlegible/files/atkinson-hyperlegible-latin-ext-400-italic.woff2?url';
import atkinsonWoff2 from '@fontsource/atkinson-hyperlegible/files/atkinson-hyperlegible-latin-ext-400-normal.woff2?url';
import workSansItalicWoff2 from '@fontsource-variable/work-sans/files/work-sans-latin-ext-wght-italic.woff2?url';
import workSansWoff2 from '@fontsource-variable/work-sans/files/work-sans-latin-ext-wght-normal.woff2?url';
import { getImage } from 'astro:assets';
import siteConfig from '../data/site-config';
import type { ImageInput } from '../types';

import '../styles/global.css';

export type Props = {
    title?: string;
    description?: string;
    image?: ImageInput | undefined;
    pageType?: 'website' | 'article';
};

const { description = '', pageType = 'website' } = Astro.props;
const rawTitle = Astro.props.title;
const title = rawTitle ? (rawTitle.includes(siteConfig.title) ? rawTitle : `${rawTitle} | ${siteConfig.title}`) : siteConfig.title;
const image = Astro.props.image ?? siteConfig.image;
let resolvedImage: { src: string; alt?: string } | undefined;
if (image?.src) {
    if (typeof image.src === 'string') {
        resolvedImage = {
            src: new URL(image.src, Astro.site).toString(),
            alt: image.alt
        };
    } else {
        const optimizedImage = await getImage({
            src: image.src as ImageMetadata,
            width: 1200,
            height: 630,
            format: 'jpeg',
            fit: 'cover'
        });
        resolvedImage = {
            src: new URL(optimizedImage.src, Astro.site).toString(),
            alt: image.alt
        };
    }
}
const canonicalURL = new URL(Astro.request.url, Astro.site);
const canonicalHref = formatCanonicalURL(canonicalURL);
const keywords = siteConfig.keywords?.join(', ');
const jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: siteConfig.author,
    url: siteConfig.website,
    description: siteConfig.description,
    jobTitle: 'Psicólogo e interventor psicosocial',
    knowsAbout: siteConfig.keywords,
    image: resolvedImage?.src,
    sameAs: siteConfig.socialLinks?.map((link) => link.href) ?? []
};

/**
 * Enforce some standard canonical URL formatting across the site.
 */
function formatCanonicalURL(url: string | URL) {
    const path = url.toString();
    const hasQueryParams = path.includes('?');
    // If there are query params, make sure the URL has no trailing slash
    if (hasQueryParams) {
        path.replace(/\/?$/, '');
    }
    // otherwise, canonical URL always has a trailing slash
    return path.replace(/\/?$/, hasQueryParams ? '' : '/');
}
---

<!-- High Priority Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="generator" content={Astro.generator} />

<!-- Fonts -->
<link rel="preload" as="font" type="font/woff2" href={atkinsonWoff2} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={atkinsonBoldWoff2} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={workSansWoff2} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={workSansItalicWoff2} crossorigin="anonymous" />
<style is:inline define:vars={{ atkinsonWoff2, atkinsonItalicWoff2, atkinsonBoldWoff2, atkinsonBoldItalicWoff2, workSansWoff2, workSansItalicWoff2 }}>
    @font-face {
        font-family: 'Atkinson Hyperlegible';
        font-style: normal;
        font-display: swap;
        font-weight: 400;
        src: url(var(--atkinsonWoff2)) format('woff2');
    }
    @font-face {
        font-family: 'Atkinson Hyperlegible';
        font-style: italic;
        font-display: swap;
        font-weight: 400;
        src: url(var(--atkinsonItalicWoff2)) format('woff2');
    }
    @font-face {
        font-family: 'Atkinson Hyperlegible';
        font-style: normal;
        font-display: swap;
        font-weight: 700;
        src: url(var(--atkinsonBoldWoff2)) format('woff2');
    }
    @font-face {
        font-family: 'Atkinson Hyperlegible';
        font-style: italic;
        font-display: swap;
        font-weight: 700;
        src: url(var(--atkinsonBoldItalicWoff2)) format('woff2');
    }
    @font-face {
        font-family: 'Work Sans Variable';
        font-style: normal;
        font-display: swap;
        font-weight: 100 900;
        src: url(var(--workSansWoff2)) format('woff2-variations');
    }
    @font-face {
        font-family: 'Work Sans Variable';
        font-style: italic;
        font-display: swap;
        font-weight: 100 900;
        src: url(var(--workSansItalicWoff2)) format('woff2-variations');
    }
</style>

<!-- Low Priority Global Metadata -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Page Metadata -->
<link rel="canonical" href={formatCanonicalURL(canonicalURL)} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />
<meta name="robots" content="index, follow" />
{keywords && <meta name="keywords" content={keywords} />}
<meta name="theme-color" content="#eeeeef" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#171717" media="(prefers-color-scheme: dark)" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType} />
<meta property="og:site_name" content={siteConfig.title} />
<meta property="og:locale" content={siteConfig.locale ?? 'es_ES'} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
{resolvedImage?.src && <meta property="og:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta property="og:image:alt" content={resolvedImage.alt} />}

<!-- X/Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalHref} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{resolvedImage?.src && <meta name="twitter:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta name="twitter:image:alt" content={resolvedImage.alt} />}

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
