---
type Props = {
    title?: string;
    to: string;
};

const { title = 'Redirigiendo', to } = Astro.props;
const canonicalHref = new URL(to, Astro.site).toString();
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex" />
        <meta http-equiv="refresh" content={`0; url=${to}`} />
        <link rel="canonical" href={canonicalHref} />
        <title>{title}</title>
    </head>
    <body>
        <p>Esta pagina se ha movido a <a href={to}>{to}</a>.</p>
    </body>
</html>
