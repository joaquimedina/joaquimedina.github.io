---
import { Image } from 'astro:assets';

type GalleryImage = {
    src: ImageMetadata;
    alt: string;
    caption?: string;
};

type Props = {
    images: GalleryImage[];
};

const { images } = Astro.props;
---

{
    images.length > 0 && (
        <div class="not-prose my-10 grid gap-5 sm:my-12 sm:grid-cols-2 sm:gap-6">
            {images.map((image) => (
                <figure class="group">
                    <a
                        class="border-main block overflow-hidden border bg-transparent p-2 focus:outline-2 focus:outline-offset-4 focus:outline-[var(--accent-cool)] sm:p-3"
                        href={image.src.src}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <Image
                            class="w-full object-cover transition duration-300 group-hover:scale-[1.015]"
                            src={image.src}
                            alt={image.alt}
                            widths={[480, 720, 960, 1200]}
                            sizes="(min-width: 832px) 360px, calc(100vw - 32px)"
                        />
                    </a>
                    {image.caption && <figcaption class="mt-2 text-sm leading-snug opacity-75">{image.caption}</figcaption>}
                </figure>
            ))}
        </div>
    )
}
