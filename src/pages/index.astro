---
import { marked } from 'marked';
import Hero from '../components/Hero.astro';
import siteConfig from '../data/site-config';
import BaseLayout from '../layouts/BaseLayout.astro';

const homeBody = siteConfig.homeContent?.body ? marked.parse(siteConfig.homeContent.body) : '';
---

<BaseLayout description={siteConfig.description}>
    <Hero {...siteConfig.hero} class="!mb-8 sm:!mb-10" />
    {homeBody && <section class="prose sm:prose-lg mb-16 max-w-none sm:mb-24 [&>*:first-child]:mt-0" set:html={homeBody} />}
</BaseLayout>
