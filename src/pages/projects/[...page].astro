---
import type { GetStaticPathsOptions, Page } from 'astro';
import { getCollection } from 'astro:content';
import RedirectPage from '../../components/RedirectPage.astro';
import siteConfig from '../../data/site-config';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
    return paginate(projects, { pageSize: siteConfig.projectsPerPage || 6 });
}

type Props = { page: Page };

const { page } = Astro.props;
const to = page.currentPage === 1 ? '/proyectos/' : `/proyectos/${page.currentPage}/`;
---

<RedirectPage title="Proyectos" to={to} />
